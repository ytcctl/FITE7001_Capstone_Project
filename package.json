{
  "name": "tokenhub-smart-contracts",
  "version": "1.0.0",
  "description": "TokenHub smart contract suite — permissioned security token platform integrated with HKSTP",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:besu": "hardhat test test/integration/besu-e2e.test.js --network besu",
    "coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:besu": "hardhat run scripts/deploy.js --network besu",
    "besu:start": "powershell -File besu/start-besu.ps1 -Detach",
    "besu:stop": "docker stop tokenhub-besu && docker rm tokenhub-besu",
    "besu:logs": "docker logs -f tokenhub-besu",
    "clean": "hardhat clean"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.4",
    "hardhat-gas-reporter": "^1.0.10"
  }
}
